# ─── General ────────────────────────────────────────────────────────────────

# Set to "true" when running in a CI environment (stricter settings, JUnit report, etc.)
CI=false

# Extra CLI flags appended to the `npx playwright test` command (e.g., --grep "my test")
PLAYWRIGHT_TEST_OPTIONS=

# ─── Ports ──────────────────────────────────────────────────────────────────

# Port for the webserver (e.g., Angular dev server)
WEBSERVER_PORT=4200

# Port for the Playwright HTML report server (used when tests fail)
REPORT_PORT=9323

# Port the Playwright UI server listens on (only for UI mode)
UI_PORT=43008

# ─── Docker / Webserver / UI ────────────────────────────────────────────────

# Set to "true" if the web server runs on the Docker host (skips launch, connects via host.docker.internal)
USE_DOCKER_HOST_WEBSERVER=false

# Override the base URL. Leave empty to auto-derive http://<host>:<port>/paste-perfect/
PLAYWRIGHT_BASE_URL=

# Set to "true" to enable file-change detection in the Playwright UI (auto-reloads tests)
FILE_CHANGES_DETECTION_SUPPORTED=false

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":automergeDigest",
    ":automergeMinor",
    ":automergePatch",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":enablePreCommit",
    ":enableVulnerabilityAlerts",
    ":semanticCommitTypeAll(refactor)",
    "config:best-practices",
    "customManagers:dockerfileVersions",
    "group:allNonMajor",
    "group:monorepos",
    "replacements:all",
    "security:minimumReleaseAgeNpm",
    "security:openssf-scorecard",
    "workarounds:all"
  ],
  "baseBranchPatterns": ["dev"],
  "schedule": ["before 6am on monday"],
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "ignorePaths": ["docker-compose.yml"],
  "ignoreUnstable": true,
  "postUpdateOptions": ["npmDedupe"],
  "rangeStrategy": "pin",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "automerge": false
  },
  "packageRules": [
    {
      "description": "Auto-merge pinned digests and patches",
      "matchUpdateTypes": ["pin", "digest"],
      "automerge": true
    },
    {
      "description": "package.json: keep caret ranges, never pin",
      "matchManagers": ["npm"],
      "matchFileNames": ["package.json", "**/package.json"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Pin everything else (Actions SHAs, Docker digests)",
      "matchManagers": ["github-actions", "dockerfile", "docker-compose"],
      "rangeStrategy": "pin",
      "pinDigests": true
    },
    {
      "description": "Never auto-merge majors — require human review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Wait 3 days after stable release before auto-merging non-majors",
      "matchUpdateTypes": ["minor", "patch"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group all Angular packages together so they always bump in lock-step",
      "groupName": "angular monorepo",
      "matchPackageNames": ["@angular/**", "@angular-devkit/**", "@schematics/**", "zone.js"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Block RC / pre-release upgrades on stable packages",
      "matchPackageNames": ["*"],
      "allowedVersions": "!/-(rc|alpha|beta|canary|next)\\./"
    }
  ]
}

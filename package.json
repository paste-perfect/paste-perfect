{
  "name": "paste-perfect",
  "version": "2.6.18-rc.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "npm run start",
    "serve:test": "ng serve --configuration=test --no-hmr",
    "serve:prod": "ng serve --configuration=production --no-hmr",
    "build-preview": "ng build --base-href /paste-perfect-test/ --configuration=production",
    "build-prod": "ng build --base-href /paste-perfect/ --configuration=production",
    "build-docker": "ng build --base-href / --configuration=production",
    "lint:check": "ng lint",
    "lint:fix": "ng lint --fix",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,html,scss}'",
    "format:fix": "prettier --write 'src/**/*.{ts,js,json,html,scss}'",
    "test": "npm run test:unit:coverage && npm run test:snapshots",
    "test:unit": "ng test --watch=false",
    "test:unit:watch": "ng test --watch",
    "test:unit:coverage": "ng test --watch=false --coverage",
    "test:unit:ci": "ng test --watch=false",
    "test:snapshots": "npm run playwright:compose -- run --rm --service-ports playwright",
    "test:snapshots:ci": "npm run playwright:compose -- run --rm -e CI=true playwright",
    "test:snapshots:ui": "npm run playwright:compose -- run --rm --service-ports playwright-ui",
    "test:snapshots:update": "npm run playwright:compose -- run --rm --service-ports -e PLAYWRIGHT_TEST_OPTIONS=--update-snapshots playwright",
    "playwright:compose": "docker compose -f config/tests/docker-compose.yml",
    "playwright:clean": "npm run playwright:compose -- down -v --remove-orphans",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@primeuix/themes": "^2.0.3",
    "@types/prismjs": "^1.26.6",
    "angular-prism": "^0.1.20",
    "ngx-clipboard": "^16.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-gherkin": "^3.1.3",
    "prettier-plugin-java": "^2.8.1",
    "prettier-plugin-kotlin": "^2.1.0",
    "prettier-plugin-nginx": "^1.0.3",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-sql": "^0.20.0",
    "prettier-plugin-toml": "^2.0.6",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "vite-plugin-prismjs": "^0.0.11",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "angular-eslint": "^21.3.1",
    "baseline-browser-mapping": "^2.10.19",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
